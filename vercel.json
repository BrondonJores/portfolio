{
  "headers": [
    {
      "source": "/index.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/sitemap.xml", "destination": "https://portfolio-hsfg.onrender.com/sitemap.xml" },
    { "source": "/api/sitemap.xml", "destination": "https://portfolio-hsfg.onrender.com/api/sitemap.xml" },
    { "source": "/(.*)", "destination": "/" }
  ]
}
