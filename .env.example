# Frontend (Vite)

# URL absolue de l API backend en production (ex: https://api.example.com)
# Laisser vide en developpement: le proxy Vite (/api) est utilise.
VITE_API_URL=

# URL publique du serveur pour les assets uploades (images)
# Laisser vide en developpement si assets servis via proxy.
VITE_SERVER_URL=
