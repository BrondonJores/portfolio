VITE_RESEND_API_KEY=your_resend_api_key_here
VITE_CONTACT_EMAIL=your_email_here

# URL absolue du backend en prod (ex: https://api.brondonjores.com)
# Laisser vide en dev : le proxy Vite prend le relais
VITE_API_URL=
# URL publique du serveur pour les assets (images uploadées, etc.)
# Laisser vide en dev
VITE_SERVER_URL=

# Configuration SMTP pour l'envoi de newsletters (côté server/)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=ton@gmail.com
SMTP_PASS=ton_app_password_gmail
