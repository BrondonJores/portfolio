PORT=5000
NODE_ENV=development

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=portfolio_db
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_SSL=false
DB_SSL_REJECT_UNAUTHORIZED=false

# JWT
JWT_ACCESS_SECRET=your_very_long_and_random_access_secret_here
JWT_REFRESH_SECRET=your_very_long_and_random_refresh_secret_here
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# 2FA / MFA (Authenticator TOTP)
# Secret dedie pour les tokens MFA (fallback sur JWT_ACCESS_SECRET/JWT_REFRESH_SECRET si vide)
JWT_MFA_SECRET=
JWT_MFA_EXPIRES=5m
JWT_MFA_SETUP_EXPIRES=10m
# Cle de chiffrement des secrets TOTP stockes en base (recommande: longue valeur aleatoire)
MFA_ENCRYPTION_KEY=
# Pepper additionnel pour hachage des recovery codes
MFA_RECOVERY_PEPPER=
# true pour desactiver les recovery codes
MFA_DISABLE_RECOVERY_CODES=false
TOTP_ISSUER=Portfolio CMS
TOTP_ALGORITHM=sha1
TOTP_DIGITS=6
TOTP_PERIOD=30
TOTP_WINDOW=1
TOTP_SECRET_BYTES=20

# CORS / URLs
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=
APP_URL=http://localhost:5000
TRUSTED_ORIGINS=
# IMPORTANT: en production, configure au moins une origine de confiance
# (sinon les endpoints sensibles bases cookie seront bloques).
# Reverse proxy (Render/Vercel/NGINX): 1 = trust first proxy hop
TRUST_PROXY=1

# Rate limiting global API
RATE_LIMIT_GLOBAL_MAX=600
RATE_LIMIT_GLOBAL_WINDOW_MS=900000
# Overrides par zone API (optionnel)
# Public fallback sur RATE_LIMIT_GLOBAL_MAX si vide.
RATE_LIMIT_PUBLIC_MAX=
RATE_LIMIT_ADMIN_MAX=
RATE_LIMIT_AUTH_MAX=

# Bootstrap admin (seed)
ADMIN_EMAIL=admin@example.com
ADMIN_USERNAME=admin
ADMIN_PASSWORD=ChangeMeNow_2026!

# Google reCAPTCHA (anti-bot)
# Active en production par defaut.
# En dev: RECAPTCHA_ENABLED=false pour ne pas bloquer les tests locaux.
RECAPTCHA_ENABLED=false
RECAPTCHA_SECRET_KEY=
RECAPTCHA_MIN_SCORE=0.5
RECAPTCHA_ALLOWED_HOSTNAMES=localhost

# Cloudinary (uploads images)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Mail delivery
# MAIL_DELIVERY_MODE: "smtp" (dev) or "brevo" (prod)
MAIL_DELIVERY_MODE=smtp
MAIL_DEBUG=false

# Provider production: Brevo API
BREVO_API_KEY=your_brevo_api_key
BREVO_SENDER_EMAIL=noreply@example.com

# Provider developpement: SMTP local (Mailpit/Mailhog/etc.)
DEV_SMTP_HOST=localhost
DEV_SMTP_PORT=1025
DEV_SMTP_SECURE=false
DEV_SMTP_USER=
DEV_SMTP_PASS=
DEV_SMTP_FROM="Portfolio Dev <noreply@localhost>"
